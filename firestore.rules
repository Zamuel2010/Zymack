rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'samadeniji852@gmail.com' &&
             request.auth.token.email_verified == true;
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    
    match /address_mappings/{addressId} {
      // Internal mappings used by the server webhook
      allow read: if isAdmin();
      allow write: if false; 
    }
    
    match /master_wallets/{chain} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /managed_wallets/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    
    match /wallets/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      
      // User can update their wallet, but NOT their totalBalance! Only Admin/Server can update totalBalance.
      allow update: if (request.auth != null && request.auth.uid == uid 
                        && request.resource.data.totalBalance == resource.data.totalBalance)
                    || isAdmin();
                    
      allow create: if request.auth != null && request.auth.uid == uid || isAdmin();
      
      match /transactions/{txId} {
        allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
        
        // User can only update isRead field
        allow update: if (request.auth != null && request.auth.uid == uid 
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']))
                      || isAdmin();
                      
        // Only Admin/Server can create or delete transactions! This prevents client-side money duplication.
        allow create: if isAdmin();
        allow delete: if isAdmin();
      }
      
      match /bankAccounts/{id} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }
      
      match /addresses/{id} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }
    }
  }
}
